{
  "dependencies": {
    "@next/eslint-plugin-next": "^16.2.1",
    "async-retry": "1.3.3",
    "dotenv": "16.4.4",
    "dotenv-expand": "11.0.6",
    "next": "13.1.6",
    "node-pg-migrate": "6.2.2",
    "nvm": "0.0.4",
    "pg": "8.11.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "name": "curso-dev",
  "version": "1.0.0",
  "description": "Desenvolvindo durante o CURSO.DEV",
  "main": "index.js",
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "commitizen": "4.3.0",
    "concurrently": "8.2.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.6.0",
    "husky": "9.1.4",
    "jest": "29.6.2",
    "prettier": "2.8.8"
  },
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && (trap 'npm run services:stop' INT TERM ; next dev)",
    "test": "npm run services:up && npm run services:wait:database && concurrently -n jest,next --hide next -k -s command-jest \"jest --runInBand --verbose\" \"next dev\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:wait:database": "node infra/scripts/waitForPostgres.js",
    "migrations:create": "node-pg-migrate --migrations-dir infra/migrations create",
    "migrations:up": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development up",
    "lint:prittier:check": "prettier --check . ",
    "lint:prittier:fix": "prettier --write .",
    "lint:eslint:check": "next lint",
    "prepare": "husky",
    "commit": "cz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vieira-gif/curso-dev.git"
  },
  "author": "João Vieira",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Vieira-gif/curso-dev/issues"
  },
  "homepage": "https://github.com/Vieira-gif/curso-dev#readme",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
